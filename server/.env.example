# ==========================================
# LiveKit Configuration for Velocity App
# ==========================================
# 1. Go to https://cloud.livekit.io/ and create a free account
# 2. Create a new "Project"
# 3. Go to Project Settings -> Keys
# 4. Generate a new API Key and Secret
# 5. Provide the WebSocket URL mapped to your project (e.g. wss://your-project.livekit.cloud)
# 
# Copy this file to `.env` and fill in the values below:

LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
# Server directory .env
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key



# Usually defaults to 4000 for this backend setup
PORT=4000
